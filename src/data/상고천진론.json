    "word": [
      {
        "id": "w1",
        "text": "上古之人",
        "reading": "상고지인",
        "meaning": "상고(고대)의 사람",
        "note": ""
      },
      {
        "id": "w2",
        "text": "知道者",
        "reading": "지도자",
        "meaning": "도를 아는 사람",
        "note": ""
      },
